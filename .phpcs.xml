<?xml version="1.0"?>
<ruleset name="RV Starter Default">
	<description>A base ruleset for RV Starter extending the PHP Coding Standards for WordPress VIP Go.</description>
	<arg name="colors" />
	<arg value="sp"/> <!-- Show sniff and progress -->
	<arg name="extensions" value="php,js"/> <!-- Limit to PHP and JS files -->

	<!-- Sets the minimum supported WP version to 6.0. -->
	<config name="minimum_supported_wp_version" value="6.4" />

	<rule ref="WordPress-VIP-Go" />
	<rule ref="WordPress">
		<exclude name="Universal.Arrays.DisallowShortArraySyntax.Found" />
		<exclude name="WordPress.Files.FileName.InvalidClassFileName" />
		<exclude name="WordPress.Files.FileName.NotHyphenatedLowercase" />
		<exclude name="Universal.Operators.DisallowShortTernary.Found" />
		<exclude name="Universal.NamingConventions.NoReservedKeywordParameterNames.functionFound" />
	</rule>

	<rule ref="WordPress.Arrays.MultipleStatementAlignment">
		<properties>
			<property name="maxColumn" value="1000"/>
		</properties>
	</rule>

	<file>themes/rv-starter</file>
	<file>vip-config</file>
	<file>client-mu-plugins</file>

	<exclude-pattern>plugins/*</exclude-pattern>
	<exclude-pattern>*/node_modules/*</exclude-pattern>
	<exclude-pattern>*/vendor/*</exclude-pattern>
	<exclude-pattern>*/dist/*</exclude-pattern>
	<exclude-pattern>.local/*</exclude-pattern>
	<exclude-pattern>.github/*</exclude-pattern>
	<exclude-pattern>.vscode/*</exclude-pattern>
	<exclude-pattern>languages/*</exclude-pattern>
	<exclude-pattern>private/*</exclude-pattern>
	<exclude-pattern>*\.(css|js)</exclude-pattern>
	<exclude-pattern>vip-config/*</exclude-pattern>

	<!-- Loads the PHP Compatibility ruleset. -->
	<rule ref="PHPCompatibilityWP" />

	<!-- Rules: WordPress Coding Standards - see
		https://github.com/WordPress-Coding-Standards/WordPress-Coding-Standards -->
	<rule ref="WordPress-Extra"/>  Includes WordPress-Core
	<rule ref="WordPress-Docs"/>

	<!--
	Prevent errors caused by WordPress Coding Standards not supporting PHP 8.0+.
	See https://github.com/WordPress/WordPress-Coding-Standards/issues/2035
	-->
	<ini name="error_reporting" value="E_ALL &#38; ~E_DEPRECATED" />

	<!-- PHP version check. -->
	<config name="testVersion" value="8.2-"/>
</ruleset>
